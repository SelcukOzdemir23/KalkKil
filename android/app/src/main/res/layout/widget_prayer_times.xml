<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_layout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="12dp"
    android:background="#0D111F">

    <!-- TÜM VAKİTLER - alt alta -->
    <TextView
        android:id="@+id/widget_all_times"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:text=""
        android:textSize="11sp"
        android:textColor="#C8D6E5"
        android:gravity="center_vertical"
        android:maxLines="6"
        android:lineSpacingExtra="4dp" />

    <!-- Ayırıcı -->
    <View
        android:layout_width="match_parent"
        android:layout_height="0.5dp"
        android:background="#3300D4FF"
        android:layout_marginVertical="6dp" />

    <!-- KALAN SÜRE (saniyesiz - dk seviyesinde) -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingTop="2dp">

        <TextView
            android:id="@+id/widget_countdown_label"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="KALAN SÜRE"
            android:textSize="9sp"
            android:textColor="#6600D4FF"
            android:textStyle="bold"
            android:letterSpacing="0.1"
            android:layout_marginEnd="8dp" />

        <TextView
            android:id="@+id/widget_countdown"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="--:--"
            android:textSize="20sp"
            android:textColor="#00D4FF"
            android:textStyle="bold"
            android:gravity="end" />
    </LinearLayout>

</LinearLayout>
